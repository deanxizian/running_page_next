{
  "name": "running-page-next",
  "description": "Strava-backed running dashboard",
  "version": "1.0.0",
  "author": "Dean Xi",
  "packageManager": "pnpm@8.9.0+sha256.8f5264ad1d100da11a6add6bb8a94c6f1e913f9e9261b2a551fabefad2ec0fec",
  "dependencies": {
    "@mapbox/polyline": "^1.2.0",
    "@math.gl/web-mercator": "^4.1.0",
    "@surbowl/world-geo-json-zh": "^2.1.5",
    "mapbox-gl": "^2.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-map-gl": "^7.1.6",
    "react-router-dom": "^6.15.0"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "data:clean": "rm -f run_page/data.db src/static/activities.json",
    "data:validate": "python3 run_page/validate_activities.py src/static/activities.json",
    "data:sync:strava": "python3 run_page/strava_sync.py \"$STRAVA_CLIENT_ID\" \"$STRAVA_CLIENT_SECRET\" \"$STRAVA_CLIENT_REFRESH_TOKEN\" --only-run",
    "build": "vite build",
    "dev": "vite dev",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "python:check": "python3 -m ruff check run_page && python3 -m ruff format --check run_page",
    "python:format": "python3 -m ruff format run_page",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "check": "pnpm typecheck && pnpm lint && pnpm format && pnpm test && pnpm build",
    "check:ci": "pnpm check && pnpm python:check && pnpm test:e2e",
    "typecheck": "tsc --noEmit",
    "serve": "vite preview"
  },
  "engineStrict": true,
  "browserslist": "defaults, not ie 11",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@rollup/wasm-node": "4.46.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mapbox-gl": "^2.7.13",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.1.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "rollup": "npm:@rollup/wasm-node@4.46.2"
    }
  }
}
